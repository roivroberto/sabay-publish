#
# Next.js / Vercel runtime values.
# `CONVEX_DEPLOYMENT`, `NEXT_PUBLIC_CONVEX_URL`, and `NEXT_PUBLIC_CONVEX_SITE_URL`
# are typically written by `pnpm convex:dev` / `npx convex dev`.
#
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

#
# Clerk
# `CLERK_JWT_ISSUER_DOMAIN` and `CLERK_WEBHOOK_SECRET` are also required in the
# Convex deployment config because Convex validates auth tokens directly and the
# Clerk webhook upsert now uses the same shared secret on both sides.
# Sync Convex-side variables with `pnpm convex:sync-env`.
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=
CLERK_WEBHOOK_SECRET=

#
# Site metadata
# `NEXT_PUBLIC_SITE_URL` is read by Next.js/Vercel, not Convex. Production
# should override this localhost default in the Vercel environment.
#
NEXT_PUBLIC_SITE_URL=http://localhost:3000

#
# Optional remote hero image allowlist.
# Leave blank to optimize only local/public assets such as
# /branding/paraluman-logo.avif. Remote hosts not listed here still render, but
# they fall back to a plain <img> instead of next/image optimization.
#
ALLOWED_IMAGE_HOSTS=

#
# Google Cloud Translation
# Variables consumed in `convex/*` should also be present in the Convex
# deployment environment.
#
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_CLOUD_PROJECT=
GCP_TRANSLATION_LOCATION=us-central1
GCP_TRANSLATION_GLOSSARY_NAME=

#
# Demo role seeding
# These values are read by Convex and should be synced there too.
#
DEMO_WRITER_EMAILS=writer@paraluman.news
DEMO_EDITOR_EMAILS=editor@paraluman.news

#
# Playwright / local E2E
# `pnpm test:e2e` starts Convex + Next automatically, uses mocked translation,
# and expects port 3000 to be free. The default writer/editor emails come from
# the allowlist vars above unless you override them here.
#
CLERK_TESTING_TOKEN=
E2E_WRITER_EMAIL=
E2E_EDITOR_EMAIL=
E2E_TRANSLATION_PREFIX=Filipino draft
